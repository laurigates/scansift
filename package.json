{
  "name": "scansift",
  "version": "0.2.0",
  "description": "Network-enabled batch photo scanning application for digitizing physical photo collections",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --filter '*' dev:server dev:client",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "vite",
    "build": "bun run build:server && bun run build:client",
    "build:server": "bun build src/server/index.ts --outdir dist/server --target bun",
    "build:client": "vite build",
    "start": "bun dist/server/index.js",
    "test": "bun run test:unit && bun run test:server",
    "test:unit": "bun test tests/client tests/detection tests/errors.test.ts tests/processing tests/scanner src/shared",
    "test:server": "bun test tests/services/scan-orchestrator.test.ts && bun test tests/routes && bun test tests/websocket && bun test tests/integration",
    "test:watch": "bun test --watch",
    "test:coverage": "bun run test:unit --coverage && bun run test:server --coverage",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "scanner:discover": "bun scripts/discover-scanners.ts",
    "scanner:test": "bun scripts/test-scan.ts",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "prepare": "pre-commit install || true",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/static": "^7.0.0",
    "@fastify/websocket": "^11.2.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "bonjour-service": "^1.2.0",
    "chrono-node": "^2.7.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "exifreader": "^4.21.0",
    "fastify": "^4.26.0",
    "fastify-socket.io": "5.1.0",
    "ky": "^1.2.0",
    "pino": "^8.17.2",
    "pino-pretty": "^13.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.2",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "tesseract.js": "^5.0.4",
    "zod": "^4.3.6",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@happy-dom/global-registrator": "^20.8.3",
    "@playwright/test": "^1.41.0",
    "@testing-library/react": "^14.1.2",
    "@types/bun": "latest",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.17",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
